<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Enviado al confirmar la orden de venta, cuando arranca el provisioning.
             El cliente recibe un segundo correo (email_template_saas_credentials)
             con sus credenciales cuando la instancia queda lista. -->
        <record id="mail_template_instance_provisioned" model="mail.template">
            <field name="name">SaaS: Instancia en Preparación</field>
            <field name="model_id" ref="odoo_k8s_saas.model_saas_instance"/>
            <field name="email_from">{{ (object.env.company.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">{{ object.partner_id.email_formatted }}</field>
            <field name="subject">Estamos preparando tu sistema Odoo — {{ object.name }}</field>
            <field name="body_html" type="html">
<div style="margin: 0; padding: 0;">
    <table width="600" style="margin: 20px auto; font-family: Arial, sans-serif; border-collapse: collapse;">
        <tr>
            <td style="background-color: #1A2238; padding: 20px; color: #fff; text-align: center; border-radius: 8px 8px 0 0;">
                <h1 style="margin: 0; font-size: 22px;">&#128640; Tu sistema Odoo está en camino</h1>
            </td>
        </tr>
        <tr>
            <td style="padding: 30px; background-color: #f9f9f9; border: 1px solid #ddd;">
                <p>Hola <strong><t t-out="object.partner_id.name or 'Cliente'"/></strong>,</p>

                <p>¡Gracias por tu compra! Ya estamos preparando tu sistema Odoo.
                El proceso toma solo unos minutos.</p>

                <table style="width: 100%; margin: 20px 0; border-collapse: collapse;">
                    <tr>
                        <td style="padding: 8px; font-weight: bold; width: 40%;">Instancia:</td>
                        <td style="padding: 8px;"><t t-out="object.name"/></td>
                    </tr>
                    <tr style="background-color: #f0f0f0;">
                        <td style="padding: 8px; font-weight: bold;">Dirección de acceso:</td>
                        <td style="padding: 8px;">
                            <a t-attf-href="{{ object.url }}" style="color: #1A2238;"><t t-out="object.url or 'Disponible en unos minutos'"/></a>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; font-weight: bold;">Plan contratado:</td>
                        <td style="padding: 8px;"><t t-out="(object.plan or 'starter').capitalize()"/></td>
                    </tr>
                    <tr style="background-color: #f0f0f0;">
                        <td style="padding: 8px; font-weight: bold;">Estado:</td>
                        <td style="padding: 8px;">
                            <span style="background-color: #f0ad4e; color: #fff; padding: 3px 10px; border-radius: 4px;">En preparación</span>
                        </td>
                    </tr>
                </table>

                <div style="background-color: #EEF0FF; border-left: 4px solid #6C63FF; padding: 15px; margin: 20px 0;">
                    <strong>&#9993; ¿Qué sigue?</strong><br/>
                    En unos minutos recibirás un segundo correo con tu
                    <strong>usuario y contraseña de administrador</strong> para ingresar a tu sistema.
                </div>

                <p>Mientras tanto, puedes gestionar tu suscripción y crear tickets de soporte desde tu portal de cliente:</p>
                <ul>
                    <li><a t-attf-href="{{ object.get_base_url() }}/my/subscriptions" style="color: #6C63FF;">Mis suscripciones</a></li>
                    <li><a t-attf-href="{{ object.get_base_url() }}/my/tickets" style="color: #6C63FF;">Soporte técnico (tickets)</a></li>
                </ul>

                <p>Saludos,<br/><strong>Equipo AEI Software</strong></p>
            </td>
        </tr>
        <tr>
            <td style="background-color: #555; padding: 15px; color: #aaa; text-align: center; font-size: 12px; border-radius: 0 0 8px 8px;">
                Mensaje automático de la plataforma AEI Software SaaS.
            </td>
        </tr>
    </table>
</div>
            </field>
        </record>

    </data>
</odoo>
