<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Kanban View -->
  <record id="view_saas_instance_kanban" model="ir.ui.view">
      <field name="name">saas.instance.kanban</field>
      <field name="model">saas.instance</field>
      <field name="arch" type="xml">
          <kanban default_group_by="state" class="o_kanban_small_column" sample="1">
              <field name="name"/>
              <field name="tenant_id"/>
              <field name="plan"/>
              <field name="state"/>
              <field name="url"/>

              <templates>
                  <t t-name="kanban-box">
                      <div class="oe_kanban_global_click">
                          <div class="oe_kanban_details">
                              <strong class="o_kanban_record_title">
                                  <field name="name"/>
                              </strong>
                              <div class="o_kanban_tags_section mt-2">
                                  <span class="badge rounded-pill text-bg-info"><field name="plan"/></span>

                                  <span t-if="record.tenant_id.raw_value" class="badge rounded-pill text-bg-light border ml-1"><field name="tenant_id"/></span>
                              </div>
                              <div class="mt-3">
                                  <a t-if="record.url.raw_value" t-att-href="record.url.raw_value" target="_blank" class="oe_kanban_action oe_kanban_action_a text-primary">
                                      <i class="fa fa-external-link"/> Open Instance
                                  </a>
                              </div>
                          </div>
                      </div>
                  </t>
              </templates>
          </kanban>
      </field>
  </record>

  <!-- Tree view -->
  <record id="view_saas_instance_tree" model="ir.ui.view">
    <field name="name">saas.instance.tree</field>
    <field name="model">saas.instance</field>
    <field name="arch" type="xml">
      <list decoration-success="state == 'ready'" decoration-warning="state in ('provisioning', 'suspended')" decoration-muted="state in ('draft', 'deleted')">
        <field name="name"/>

        <field name="tenant_id"/>
        <field name="plan" widget="badge" decoration-info="plan == 'pro'" decoration-success="plan == 'enterprise'"/>
        <field name="state" widget="badge"
               decoration-success="state == 'ready'"
               decoration-warning="state == 'provisioning'"
               decoration-danger="state == 'error'"
               decoration-muted="state in ('draft', 'deleted')"/>
        <field name="url" widget="url"/>
        <field name="partner_id" optional="show"/>
      </list>
    </field>
  </record>

  <!-- Form view -->
  <record id="view_saas_instance_form" model="ir.ui.view">
    <field name="name">saas.instance.form</field>
    <field name="model">saas.instance</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_check_availability" type="object" string="Check Availability"
                  class="btn-secondary"
                  invisible="state not in ('draft', 'error')"/>
          <button name="action_provision" type="object" string="Provision"
                  class="btn-primary"
                  invisible="state not in ('draft', 'error')"/>
          <button name="action_check_status" type="object" string="Refresh Status"
                  invisible="state != 'provisioning'"/>
          <button name="action_stop" type="object" string="Suspend"
                  class="btn-warning"
                  invisible="state != 'ready'"/>
          <button name="action_resume" type="object" string="Resume"
                  class="btn-success"
                  invisible="state != 'suspended'"/>
          <button name="action_delete" type="object" string="Delete Instance"
                  class="btn-danger"
                  invisible="state in ('draft', 'deleted')"/>
          <field name="state" widget="statusbar"
                 statusbar_visible="draft,provisioning,ready,suspended"/>
        </header>
        <sheet>
          <div class="oe_button_box" name="button_box">
              <button name="action_open_url"
                      type="object"
                      class="oe_stat_button"
                      icon="fa-globe"
                      invisible="not url">
                  <div class="o_stat_info">
                      <span class="o_stat_text">Open Instance</span>
                  </div>
              </button>
          </div>
          <widget name="web_ribbon" title="Ready" bg_color="text-bg-success" invisible="state != 'ready'"/>
          <widget name="web_ribbon" title="Error" bg_color="text-bg-danger" invisible="state != 'error'"/>
          <widget name="web_ribbon" title="Provisioning" bg_color="text-bg-warning" invisible="state != 'provisioning'"/>
          <widget name="web_ribbon" title="Suspended" bg_color="text-bg-warning" invisible="state != 'suspended'"/>
          <widget name="web_ribbon" title="Deleted" bg_color="text-bg-secondary" invisible="state != 'deleted'"/>

          <div class="oe_title">
              <h1><field name="name" placeholder="e.g. My Great Company SA"/></h1>
          </div>
          <group>
            <group string="Identity">
              <field name="tenant_id" placeholder="e.g. my-company"/>
              <field name="partner_id"/>
              <field name="sale_order_id" readonly="1"/>

            </group>
            <group string="Configuration">
              <field name="plan"/>
              <field name="storage_gi"/>
              <field name="url" widget="url" readonly="1"/>
              <field name="namespace" readonly="1"/>
            </group>
          </group>

          <!-- ─── Notebook with Config / Logs / Addons ─── -->
          <notebook invisible="state == 'draft'">
            <page string="⚙ Configuration" name="config_page"
                  invisible="state not in ('ready', 'provisioning')">
              <group>
                <div class="d-flex gap-2 mb-3">
                  <button name="action_fetch_config" type="object"
                          string="⟳ Fetch Config" class="btn-secondary"
                          invisible="state not in ('ready', 'provisioning')"/>
                  <button name="action_save_config" type="object"
                          string="💾 Save Config" class="btn-primary"
                          invisible="state != 'ready'"
                          confirm="This will overwrite odoo.conf and restart the pod. Continue?"/>
                </div>
              </group>
              <field name="odoo_conf" nolabel="1"
                     placeholder="Click 'Fetch Config' to load the current odoo.conf..."
                     class="o_field_text" style="font-family: monospace; min-height: 300px;"/>
            </page>

            <page string="📜 Logs" name="logs_page"
                  invisible="state in ('draft', 'deleted')">
              <group>
                <button name="action_fetch_logs" type="object"
                        string="⟳ Refresh Logs" class="btn-secondary"/>
              </group>
              <field name="pod_logs" nolabel="1" readonly="1"
                     placeholder="Click 'Refresh Logs' to load the latest pod output..."
                     class="o_field_text" style="font-family: monospace; min-height: 300px; white-space: pre-wrap;"/>
            </page>

            <page string="📦 Addon Repos" name="addons_page">
              <group>
                <div class="alert alert-info" role="alert">
                  Enter a JSON array of repos. Each object needs <code>url</code> and
                  <code>branch</code>.  Example:
                  <code>[{"url": "https://github.com/org/repo.git", "branch": "18.0"}]</code>
                </div>
                <field name="addons_repos_json" nolabel="1" widget="text"
                       placeholder='[{"url": "https://github.com/org/repo.git", "branch": "18.0"}]'
                       style="font-family: monospace; min-height: 120px;"/>
                <button name="action_patch_addons" type="object"
                        string="🔄 Sync Addons to Instance" class="btn-primary"
                        invisible="state != 'ready'"
                        confirm="This will update the addon repos and restart the tenant pod. Continue?"/>
              </group>
            </page>
          </notebook>

          <group string="Error Details" invisible="not error_msg" col="1">
            <field name="error_msg" nolabel="1" class="text-danger"/>
          </group>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <!-- Action -->
  <record id="action_saas_instances" model="ir.actions.act_window">
    <field name="name">SaaS Instances</field>
    <field name="res_model">saas.instance</field>
    <field name="view_mode">kanban,list,form</field>
    <field name="help" type="html">
      <p class="o_view_nocontent_smiling_face">
        Create your first SaaS Instance
      </p>
      <p>
        Provision and manage tenant databases on your Kubernetes cluster easily.
      </p>
    </field>
  </record>

  <!-- Menu item under Technical -->
  <menuitem id="menu_saas_root" name="SaaS" sequence="99" web_icon="odoo_k8s_saas,static/description/icon.png"/>
  <menuitem id="menu_saas_instances" name="Instances"
            parent="menu_saas_root"
            action="action_saas_instances" sequence="10"/>
</odoo>
