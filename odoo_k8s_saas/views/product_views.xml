<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_saas" model="ir.ui.view">
        <field name="name">product.template.form.saas</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page name="saas_config" string="SaaS Configuration">
                    <group>
                        <group name="saas_settings" string="Provisioning Options">
                            <field name="odoo_version"/>
                            <field name="custom_image" invisible="odoo_version != 'custom'"/>
                            <field name="install_modules" placeholder="e.g. aei_setup" invisible="False"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
