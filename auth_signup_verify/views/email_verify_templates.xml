<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="email_verify_pending" name="Signup — Verify Email Pending">
        <t t-call="web.frontend_layout">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-md-6 text-center">
                        <h2>Confirm your email</h2>
                        <p class="lead">
                            We sent a confirmation link to
                            <strong t-esc="email"/>.
                        </p>
                        <p>
                            Please open it to activate your account. You will be
                            able to sign in once your email is confirmed.
                        </p>
                        <a href="/web/login" class="btn btn-primary mt-3">Back to login</a>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="email_verify_result" name="Signup — Email Verification Result">
        <t t-call="web.frontend_layout">
            <div class="container py-5">
                <div class="row justify-content-center">
                    <div class="col-md-6 text-center">
                        <t t-if="ok">
                            <h2>Email confirmed</h2>
                            <p class="lead">Your account is now active. You can sign in.</p>
                            <a href="/web/login" class="btn btn-primary mt-3">Sign in</a>
                        </t>
                        <t t-else="">
                            <h2>Link invalid or expired</h2>
                            <p class="lead">
                                This confirmation link is no longer valid. Try signing
                                up again or contact support.
                            </p>
                            <a href="/web/signup" class="btn btn-secondary mt-3">Back to signup</a>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
