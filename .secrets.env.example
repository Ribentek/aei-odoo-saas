# =============================================================================
# .secrets.env.example — copy this to .secrets.env and fill in real values
#
# Usage:
#   cp .secrets.env.example .secrets.env
#   # edit .secrets.env with real passwords
#   ./infra/apply-manifests.sh        # production deploy
#   ./dev-setup.sh                    # local dev bootstrap
#
# NEVER commit .secrets.env — it is gitignored.
# =============================================================================

# PostgreSQL password for the 'odoo' superuser.
# Must be the same value used when the postgres pod was first initialised.
# To rotate: update here, run apply-manifests.sh, then ALTER ROLE odoo PASSWORD '...' in psql.
DB_PASSWORD=change_me

# Odoo master password (used in the database manager UI and odoo.conf admin_passwd).
# Can differ from DB_PASSWORD.
ADMIN_PASSWD=change_me

# Portal API key — shared between the portal service and the odoo_k8s_saas addon.
API_KEY=change_me

# Cloudflare Tunnel token — get from Cloudflare Zero Trust dashboard.
CLOUDFLARE_TUNNEL_TOKEN=change_me

# =============================================================================
# Backup system (k8s/backup/) — CronJobs pg_dump + filestore → RadosGW S3
# =============================================================================

# S3 credentials for the RadosGW user used by K8s backup CronJobs.
# Reuses the 'pgbackrest' RadosGW user already configured in the PG VMs.
# To retrieve the values from a PG node:
#   ssh ubuntu@10.40.2.182 "sudo grep 'repo1-s3-key' /etc/pgbackrest/pgbackrest.conf"
BACKUP_S3_ACCESS_KEY=change_me
BACKUP_S3_SECRET_KEY=change_me

# RadosGW endpoint (HTTP — traffic stays on 10.40.1.x private VLAN).
BACKUP_S3_ENDPOINT=http://10.40.1.240:7480

# Bucket where pgBackRest and K8s dumps land (shared, different prefixes).
BACKUP_S3_BUCKET=pg-backups

# PostgreSQL superuser password (role 'postgres').
# Different from DB_PASSWORD which is the 'odoo' role password.
# Retrieve from a PG VM:
#   ssh ubuntu@10.40.2.182 "sudo grep -A2 'superuser:' /etc/patroni/patroni.yml"
BACKUP_PG_SUPERUSER_PASSWORD=change_me

# Shared secret between the portal FastAPI and the odoo_k8s_saas_subscription webhook receiver.
# Must match on both sides: portal env ODOO_WEBHOOK_KEY = Odoo env SAAS_WEBHOOK_KEY.
# Generate with: openssl rand -hex 32
SAAS_WEBHOOK_KEY=change_me