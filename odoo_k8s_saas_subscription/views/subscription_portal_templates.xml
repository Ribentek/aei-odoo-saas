<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════
         Breadcrumbs
         ═══════════════════════════════════════════════════════════ -->
    <template
        id="portal_my_home_menu_subscription"
        name="Portal layout : Subscription menu entries"
        inherit_id="portal.portal_breadcrumbs"
        priority="35"
    >
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li
                t-if="page_name == 'Subscriptions'"
                t-attf-class="breadcrumb-item #{'active ' if not subscription else ''}"
            >
                <a
                    t-if="subscription"
                    t-attf-href="/my/subscriptions?{{ keep_query() }}"
                >Subscriptions</a>
                <t t-else="">Subscriptions</t>
            </li>
            <li t-if="subscription" class="breadcrumb-item active">
                <t t-esc="subscription.name" />
            </li>
        </xpath>
    </template>

    <!-- ═══════════════════════════════════════════════════════════
         /my Homepage entry
         ═══════════════════════════════════════════════════════════ -->
    <template
        id="portal_my_home_subscription"
        name="Show Subscriptions"
        inherit_id="portal.portal_my_home"
        priority="30"
    >
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/odoo_k8s_saas_subscription/static/src/img/subscription_icon.svg'" />
                <t t-set="title">Subscriptions</t>
                <t t-set="url" t-value="'/my/subscriptions'" />
                <t t-set="placeholder_count" t-value="'subscription_count'" />
                <t t-set="show_count" t-value="True" />
            </t>
        </div>
    </template>

    <!-- ═══════════════════════════════════════════════════════════
         /my/subscriptions — List view
         ═══════════════════════════════════════════════════════════ -->
    <template id="portal_my_subscriptions" name="My Subscriptions">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Subscriptions</t>
            </t>
            <t t-if="subscriptions" t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th>Subscription</th>
                        <th class="d-none d-md-table-cell">Stage</th>
                        <th class="d-none d-md-table-cell">Next Invoice</th>
                        <th class="text-end">Recurring Total</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="subscriptions" t-as="sub">
                        <tr>
                            <td>
                                <a
                                    t-att-href="sub.get_portal_url()"
                                    t-att-title="sub.name"
                                >
                                    <t t-esc="sub.name" />
                                </a>
                            </td>
                            <td class="d-none d-md-table-cell">
                                <span
                                    t-if="sub.stage_id"
                                    class="badge rounded-pill text-bg-info"
                                    t-esc="sub.stage_id.name"
                                />
                            </td>
                            <td class="d-none d-md-table-cell">
                                <span t-field="sub.recurring_next_date" />
                            </td>
                            <td class="text-end">
                                <span
                                    t-field="sub.recurring_total"
                                    t-options='{"widget": "monetary", "display_currency": sub.currency_id}'
                                />
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
            <p t-if="not subscriptions" class="text-muted">
                There are currently no subscriptions for your account.
            </p>
        </t>
    </template>

    <!-- ═══════════════════════════════════════════════════════════
         /my/subscriptions/<id> — Detail view
         ═══════════════════════════════════════════════════════════ -->
    <template id="portal_subscription_page" name="My Subscription">
        <t t-call="portal.portal_layout">
            <!-- Back-to-edit for internal users -->
            <t groups="subscription_oca.group_subscription_oca_manager">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t
                        t-set="backend_url"
                        t-value="'/web#return_label=Website&amp;model=sale.subscription&amp;id=%s&amp;view_type=form' % (subscription.id)"
                    />
                </t>
            </t>

            <!-- Header -->
            <h5 class="mb-0">
                <span>
                    Subscription —
                    <span t-field="subscription.name" />
                </span>
                <span
                    t-if="subscription.stage_id"
                    class="badge rounded-pill text-bg-info ms-2"
                    t-esc="subscription.stage_id.name"
                />
            </h5>

            <div id="general_information">
                <!-- Customer / Responsible -->
                <div class="row mt-4">
                    <div
                        t-if="subscription.partner_id"
                        class="col-12 col-md-6 mb-4 mb-md-0"
                    >
                        <h6><strong>Customer:</strong></h6>
                        <div class="row">
                            <div class="col flex-grow-0 pe-3">
                                <img
                                    t-if="subscription.partner_id.image_128"
                                    class="rounded-circle mt-1 o_portal_contact_img"
                                    t-att-src="image_data_uri(subscription.partner_id.image_128)"
                                    alt="Contact"
                                />
                                <img
                                    t-else=""
                                    class="rounded-circle mt-1 o_portal_contact_img"
                                    src="/web/static/src/img/user_menu_avatar.png"
                                    alt="Contact"
                                />
                            </div>
                            <div class="col ps-sm-0">
                                <address
                                    t-field="subscription.partner_id"
                                    t-options='{"widget": "contact", "fields": ["name", "email", "phone"]}'
                                />
                            </div>
                        </div>
                    </div>
                    <div t-if="subscription.user_id" class="col-12 col-md-6">
                        <h6><strong>Commercial Agent:</strong></h6>
                        <div class="row">
                            <div class="col flex-grow-0 pe-3">
                                <img
                                    t-if="subscription.user_id.image_128"
                                    class="rounded-circle mt-1 o_portal_contact_img"
                                    t-att-src="image_data_uri(subscription.user_id.image_128)"
                                    alt="Contact"
                                />
                                <img
                                    t-else=""
                                    class="rounded-circle mt-1 o_portal_contact_img"
                                    src="/web/static/src/img/user_menu_avatar.png"
                                    alt="Contact"
                                />
                            </div>
                            <div class="col ps-sm-0">
                                <address
                                    t-field="subscription.user_id"
                                    t-options='{"widget": "contact", "fields": ["name", "email", "phone"]}'
                                />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Subscription details -->
                <div class="row mt-4" id="subscription_details">
                    <div class="col-12 col-md-6 mb-4 mb-md-0">
                        <div t-if="subscription.code" class="row mb-2 mb-sm-1">
                            <div class="col-12 col-sm-4"><strong>Reference</strong></div>
                            <div class="col-12 col-sm-8">
                                <span t-field="subscription.code" />
                            </div>
                        </div>
                        <div t-if="subscription.template_id" class="row mb-2 mb-sm-1">
                            <div class="col-12 col-sm-4"><strong>Plan</strong></div>
                            <div class="col-12 col-sm-8">
                                <span t-field="subscription.template_id" />
                            </div>
                        </div>
                        <div t-if="subscription.date_start" class="row mb-2 mb-sm-1">
                            <div class="col-12 col-sm-4"><strong>Start Date</strong></div>
                            <div class="col-12 col-sm-8">
                                <span
                                    t-field="subscription.date_start"
                                    t-options='{"widget": "date"}'
                                />
                            </div>
                        </div>
                        <div t-if="subscription.recurring_next_date" class="row mb-2 mb-sm-1">
                            <div class="col-12 col-sm-4"><strong>Next Invoice</strong></div>
                            <div class="col-12 col-sm-8">
                                <span
                                    t-field="subscription.recurring_next_date"
                                    t-options='{"widget": "date"}'
                                />
                            </div>
                        </div>
                        <div t-if="subscription.date" class="row mb-2 mb-sm-1">
                            <div class="col-12 col-sm-4"><strong>End Date</strong></div>
                            <div class="col-12 col-sm-8">
                                <span
                                    t-field="subscription.date"
                                    t-options='{"widget": "date"}'
                                />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SaaS Instance(s) -->
                <div t-if="saas_instances" id="saas_instance_details" class="mt-4">
                    <h6><strong>Your SaaS Instance</strong></h6>
                    <t t-foreach="saas_instances" t-as="inst">
                        <div class="card mb-2">
                            <div class="card-body py-2 px-3">
                                <div class="row align-items-center">
                                    <div class="col-12 col-md-4">
                                        <small class="text-muted">Instance URL</small><br/>
                                        <a t-if="inst.url and inst.state == 'ready'"
                                           t-att-href="inst.url"
                                           target="_blank"
                                           class="fw-bold">
                                            <i class="fa fa-external-link me-1"/>
                                            <t t-esc="inst.url"/>
                                        </a>
                                        <span t-elif="inst.url" class="text-muted">
                                            <t t-esc="inst.url"/>
                                        </span>
                                        <span t-else="" class="text-muted fst-italic">
                                            URL not yet assigned
                                        </span>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <small class="text-muted">Status</small><br/>
                                        <span t-if="inst.state == 'ready'"
                                              class="badge rounded-pill text-bg-success">
                                            <i class="fa fa-check me-1"/>Ready
                                        </span>
                                        <span t-elif="inst.state == 'provisioning'"
                                              class="badge rounded-pill text-bg-warning">
                                            <i class="fa fa-spinner fa-spin me-1"/>Provisioning…
                                        </span>
                                        <span t-elif="inst.state == 'suspended'"
                                              class="badge rounded-pill text-bg-secondary">
                                            <i class="fa fa-pause me-1"/>Suspended
                                        </span>
                                        <span t-elif="inst.state == 'error'"
                                              class="badge rounded-pill text-bg-danger">
                                            <i class="fa fa-exclamation-triangle me-1"/>Error
                                        </span>
                                        <span t-else=""
                                              class="badge rounded-pill text-bg-light">
                                            <t t-esc="inst.state"/>
                                        </span>
                                    </div>
                                    <div class="col-6 col-md-2">
                                        <small class="text-muted">Plan</small><br/>
                                        <span class="text-capitalize" t-esc="inst.plan"/>
                                    </div>
                                    <div class="col-12 col-md-3 text-md-end mt-2 mt-md-0">
                                        <a t-if="inst.url and inst.state == 'ready'"
                                           t-att-href="inst.url"
                                           target="_blank"
                                           class="btn btn-sm btn-primary">
                                            <i class="fa fa-sign-in me-1"/>Open Instance
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <!-- User Usage -->
                <div t-if="subscription.template_id and subscription.template_id.included_users"
                     id="user_billing_details" class="mt-4">
                    <h6><strong>User Usage</strong></h6>
                    <div class="card">
                        <div class="card-body py-2 px-3">
                            <div class="row">
                                <div class="col-6 col-md-3">
                                    <small class="text-muted">Current Users</small><br/>
                                    <strong><t t-esc="subscription.current_user_count"/></strong>
                                </div>
                                <div class="col-6 col-md-3">
                                    <small class="text-muted">Included in Plan</small><br/>
                                    <span t-esc="subscription.template_id.included_users"/>
                                </div>
                                <div class="col-6 col-md-3">
                                    <small class="text-muted">Extra Users</small><br/>
                                    <span t-esc="subscription.extra_users"/>
                                </div>
                                <div class="col-6 col-md-3">
                                    <small class="text-muted">Extra Charges</small><br/>
                                    <span t-field="subscription.extra_users_amount"
                                          t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Estimated Next Invoice (shown only when extra users generate charges) -->
                <div t-if="subscription.extra_users_amount"
                     class="alert alert-info mt-3" id="estimated_next_invoice">
                    <i class="fa fa-calculator me-1"/>
                    <strong>Estimated Next Invoice:</strong>
                    <span t-field="subscription.recurring_total"
                          t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'/>
                    +
                    <span t-field="subscription.extra_users_amount"
                          t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'/>
                    (extra users) =
                    <strong>
                        <t t-esc="'%.2f' % (subscription.recurring_total + subscription.extra_users_amount)"/>
                        <t t-esc="subscription.currency_id.symbol or 'Bs.'"/>
                    </strong>
                </div>

                <!-- Line items table -->
                <div id="item_details">
                    <table class="table table-sm mt-4" id="subscription_lines_table">
                        <thead class="bg-100">
                            <tr>
                                <th name="th_name" class="text-start">Description</th>
                                <th name="th_quantity" class="text-end">Quantity</th>
                                <th name="th_price_unit" class="text-end">Unit Price</th>
                                <th name="th_discount" class="text-end">Discount (%)</th>
                                <th name="th_price_subtotal" class="text-end">Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t
                                t-foreach="subscription.sale_subscription_line_ids"
                                t-as="line"
                            >
                                <tr>
                                    <td name="td_name">
                                        <span t-field="line.name" />
                                    </td>
                                    <td name="td_quantity" class="text-end">
                                        <span t-field="line.product_uom_qty" />
                                    </td>
                                    <td name="td_price_unit" class="text-end">
                                        <span
                                            t-field="line.price_unit"
                                            t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'
                                        />
                                    </td>
                                    <td name="td_discount" class="text-end">
                                        <span t-field="line.discount" />
                                    </td>
                                    <td name="td_price_subtotal" class="text-end">
                                        <span
                                            t-field="line.price_subtotal"
                                            t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'
                                        />
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Totals -->
                <div class="row justify-content-end mt-3">
                    <div class="col-12 col-md-4">
                        <table class="table table-sm">
                            <tr>
                                <td><strong>Recurring Total</strong></td>
                                <td class="text-end">
                                    <span
                                        t-field="subscription.recurring_total"
                                        t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'
                                    />
                                </td>
                            </tr>
                            <tr t-if="subscription.amount_tax">
                                <td>Taxes</td>
                                <td class="text-end">
                                    <span
                                        t-field="subscription.amount_tax"
                                        t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'
                                    />
                                </td>
                            </tr>
                            <tr class="border-top">
                                <td><strong>Total</strong></td>
                                <td class="text-end">
                                    <strong>
                                        <span
                                            t-field="subscription.amount_total"
                                            t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'
                                        />
                                    </strong>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                <!-- Estimated next invoice (shows when extra users exist) -->
                <div t-if="subscription.extra_users > 0" class="alert alert-warning mt-3 mb-0">
                    <div class="row align-items-center">
                        <div class="col-12 col-md-8">
                            <i class="fa fa-exclamation-triangle me-1"/>
                            <strong>You have <t t-esc="subscription.extra_users"/> user(s) beyond your plan.</strong>
                            <br/>
                            <small class="text-muted">
                                Extra charge:
                                <t t-esc="subscription.extra_users"/> users ×
                                <span t-field="subscription.template_id.price_per_extra_user"
                                      t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'/>
                                /user/month =
                                <strong>
                                    <span t-field="subscription.extra_users_amount"
                                          t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'/>
                                </strong>
                            </small>
                        </div>
                        <div class="col-12 col-md-4 text-md-end mt-2 mt-md-0">
                            <small class="text-muted">Estimated next invoice:</small><br/>
                            <strong class="fs-5">
                                <t t-set="estimated_total" t-value="subscription.recurring_total + subscription.extra_users_amount"/>
                                <t t-esc="'%.2f' % estimated_total"/>
                                <t t-esc="subscription.currency_id.symbol"/>
                            </strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Self-service Actions -->
            <div id="subscription_actions" class="mt-4">

                <!-- Success banners -->
                <div t-if="cancelled" class="alert alert-success">
                    <i class="fa fa-check-circle me-2"/>
                    <strong>Suscripción cancelada.</strong>
                    Tu instancia será suspendida y los datos conservados durante 7 días.
                </div>
                <div t-if="upgraded" class="alert alert-success">
                    <i class="fa fa-check-circle me-2"/>
                    <strong>Plan actualizado correctamente.</strong>
                    Los nuevos recursos se aplicarán en los próximos minutos.
                </div>

                <!-- Action buttons (only for active subscriptions) -->
                <t t-set="stage_name" t-value="subscription.stage_id.name or ''"/>
                <t t-if="'progress' in stage_name.lower() or 'progreso' in stage_name.lower() or 'activ' in stage_name.lower() or 'curso' in stage_name.lower()">
                    <div class="d-flex gap-2 flex-wrap">

                        <!-- Upgrade/Downgrade plan -->
                        <t t-if="saas_templates">
                            <a t-attf-href="/my/subscriptions/{{ subscription.id }}/upgrade"
                               class="btn btn-outline-primary">
                                <i class="fa fa-arrow-up me-1"/>
                                Cambiar plan
                            </a>
                        </t>

                        <!-- Cancel subscription — opens confirmation modal -->
                        <button type="button" class="btn btn-outline-danger"
                                data-bs-toggle="modal" data-bs-target="#cancelModal">
                            <i class="fa fa-times-circle me-1"/>
                            Cancelar suscripción
                        </button>
                    </div>

                    <!-- Cancel confirmation modal -->
                    <div class="modal fade" id="cancelModal" tabindex="-1" aria-labelledby="cancelModalLabel" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header bg-danger text-white">
                                    <h5 class="modal-title" id="cancelModalLabel">
                                        <i class="fa fa-exclamation-triangle me-2"/>
                                        Confirmar cancelación
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white"
                                            data-bs-dismiss="modal" aria-label="Close"/>
                                </div>
                                <div class="modal-body">
                                    <p>¿Estás seguro de que deseas cancelar la suscripción
                                    <strong><t t-esc="subscription.name"/></strong>?</p>
                                    <ul class="text-muted small">
                                        <li>Tu instancia de Odoo será <strong>suspendida</strong> inmediatamente.</li>
                                        <li>Los datos se conservarán durante <strong>7 días</strong>.</li>
                                        <li>Después del período de gracia, la instancia se eliminará definitivamente.</li>
                                        <li>Esta acción no puede deshacerse.</li>
                                    </ul>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary"
                                            data-bs-dismiss="modal">Mantener suscripción</button>
                                    <form t-attf-action="/my/subscriptions/{{ subscription.id }}/cancel"
                                          method="POST" class="d-inline">
                                        <input type="hidden" name="csrf_token"
                                               t-att-value="request.csrf_token()"/>
                                        <button type="submit" class="btn btn-danger">
                                            <i class="fa fa-times-circle me-1"/>
                                            Sí, cancelar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

        </t>
    </template>

    <!-- ═══════════════════════════════════════════════════════════
         /my/subscriptions/<id>/upgrade — Plan change confirmation
         ═══════════════════════════════════════════════════════════ -->
    <template id="portal_upgrade_confirmation" name="Upgrade Plan Confirmation">
        <t t-call="portal.portal_layout">
            <h5 class="mb-3">Cambiar plan — <t t-esc="subscription.name"/></h5>

            <!-- Current plan card -->
            <div class="card mb-4 border-primary">
                <div class="card-header bg-primary text-white">
                    <strong>Plan actual</strong>
                </div>
                <div class="card-body">
                    <h5 class="card-title"><t t-esc="subscription.template_id.name"/></h5>
                    <div class="row text-muted small">
                        <div class="col-4">
                            <strong>Usuarios incluidos</strong><br/>
                            <t t-esc="subscription.template_id.included_users"/>
                        </div>
                        <div class="col-4">
                            <strong>Extra por usuario</strong><br/>
                            <span t-field="subscription.template_id.price_per_extra_user"
                                  t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'/>/mes
                        </div>
                        <div class="col-4">
                            <strong>Almacenamiento</strong><br/>
                            <t t-esc="subscription.template_id.storage_gi"/> GB
                        </div>
                    </div>
                </div>
            </div>

            <!-- Available plans -->
            <h6 class="mb-3">Selecciona el nuevo plan:</h6>
            <div class="row g-3">
                <t t-foreach="saas_templates" t-as="tmpl">
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100">
                            <div class="card-header text-center">
                                <strong><t t-esc="tmpl.name"/></strong>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled small text-muted">
                                    <li><i class="fa fa-users me-2"/>
                                        <t t-esc="tmpl.included_users"/> usuarios incluidos</li>
                                    <li><i class="fa fa-hdd-o me-2"/>
                                        <t t-esc="tmpl.storage_gi"/> GB almacenamiento</li>
                                    <li><i class="fa fa-plus me-2"/>
                                        <span t-field="tmpl.price_per_extra_user"
                                              t-options='{"widget": "monetary", "display_currency": subscription.currency_id}'/>/usuario extra/mes</li>
                                </ul>
                            </div>
                            <div class="card-footer text-center">
                                <form t-attf-action="/my/subscriptions/{{ subscription.id }}/upgrade"
                                      method="POST">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="new_template_id"
                                           t-att-value="tmpl.id"/>
                                    <button type="submit" class="btn btn-primary btn-sm w-100">
                                        <i class="fa fa-check me-1"/>
                                        Cambiar a este plan
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <div class="mt-4">
                <a t-attf-href="/my/subscriptions/{{ subscription.id }}"
