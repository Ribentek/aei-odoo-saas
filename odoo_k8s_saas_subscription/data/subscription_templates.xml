<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── SaaS Subscription Templates ────────────────────────────── -->
        <record id="subscription_template_saas_starter" model="sale.subscription.template">
            <field name="name">SaaS Starter (Monthly)</field>
            <field name="is_saas_plan" eval="True"/>
            <field name="recurring_interval">1</field>
            <field name="recurring_rule_type">months</field>
            <field name="included_users">3</field>
            <field name="price_per_extra_user">5.0</field>
            <field name="plan">starter</field>
            <field name="storage_gi">10</field>
        </record>


        <record id="subscription_template_saas_pro" model="sale.subscription.template">
            <field name="name">SaaS Pro (Monthly)</field>
            <field name="is_saas_plan" eval="True"/>
            <field name="recurring_interval">1</field>
            <field name="recurring_rule_type">months</field>
            <field name="included_users">10</field>
            <field name="price_per_extra_user">3.0</field>
            <field name="plan">pro</field>
            <field name="storage_gi">20</field>
        </record>

        <record id="subscription_template_saas_enterprise" model="sale.subscription.template">
            <field name="name">SaaS Enterprise (Monthly)</field>
            <field name="is_saas_plan" eval="True"/>
            <field name="recurring_interval">1</field>
            <field name="recurring_rule_type">months</field>
            <field name="included_users">50</field>
            <field name="price_per_extra_user">2.0</field>
            <field name="plan">enterprise</field>
            <field name="storage_gi">50</field>
        </record>

    </data>
</odoo>

